# Wallet (same EVM key controls Arbitrum + Hyperliquid)
PRIVATE_KEY=0x...
WALLET_ADDRESS=0x...

# RPC endpoints (Alchemy preferred; HyperEVM public fallback provided)
ALCHEMY_ARBITRUM_RPC=https://arb-mainnet.g.alchemy.com/v2/<your-key>
HYPER_EVM_RPC=https://rpc.hyperliquid.xyz/evm

# DCA parameters
MA_THRESHOLD_USD=28.00     # Buy only when 2h MA is below this price (USD)
MA_PERIODS=20              # Number of 2h candles in the MA window (20 = ~40 hours)
DAILY_BUY_USDC=10.0        # USDC to spend per triggered buy
MIN_SPOT_ORDER_USDC=10.0   # Hyperliquid spot minimum order value
BUY_COOLDOWN_HOURS=24.0    # Prevent repeated buys when run-once is scheduled frequently

# Bridge parameters (auto-bridge from Arbitrum when HyperCore balance is low)
BRIDGE_BUFFER_DAYS=7       # Bridge triggered when balance < N days of buys (default $70)
BRIDGE_BATCH_DAYS=14       # Batch size to bridge at once (default $140)
BRIDGE_ATTESTATION_WAIT_SECONDS=0  # 0 = check once and exit; launchd will retry
BRIDGE_ATTESTATION_POLL_SECONDS=30
